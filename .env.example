# mcp-nixreview configuration. No secrets required (the CISA KEV feed is keyless).
# Copy to .env and adjust as needed. .env is gitignored.

# --- MCP server ---
MCP_HOST=0.0.0.0
MCP_PORT=3722

# --- Storage (audit ledger, review state, KEV cache) ---
DATA_DIR=/data

# --- CISA KEV feed ---
KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
KEV_TTL_HOURS=24
KEV_FETCH_TIMEOUT_SECONDS=30

# --- Timestamps / logging ---
TZ=America/New_York
LOG_LEVEL=INFO
LOG_FORMAT=json
